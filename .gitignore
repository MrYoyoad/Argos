# ==================================================
# VSP Pipeline Root .gitignore
# ==================================================
# Created: 2026-01-29
# Purpose: Exclude large data directories, models, and build artifacts

# ---------- Data Directories (Large, Generated) ----------
# These are generated by pipeline runs and should not be tracked
vsp_input/              # User input videos (100MB+)
flat/                   # Copied raw videos
flat_wrd/               # ASR transcription outputs
flat_txt/               # Text format transcriptions
preprocess_ready_flat/  # Preprocessed directory structure
preprocessed_flat_seg*/ # Segmented videos (any segment duration: seg4, seg12, etc.)
flat_runs_archive/      # Archived pipeline outputs
flat_features/          # Extracted HuBERT features
flat_labels/            # K-means cluster labels
decode/                 # Decoding outputs

# EXCEPTION: .transcriptions should be optionally tracked for backup
# Uncomment below to track transcriptions in git
# !vsp_input/.transcriptions/
# !vsp_input/.transcriptions/*.wrd
# !vsp_input/.transcriptions/metadata.json

# ---------- Python Virtual Environments ----------
*-venv/
venv/
.venv/
env/
pre-process-venv/
vsp-llm-yoad-venv/
project/ron/.venv/

# ---------- Python Build Artifacts ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
!scripts/build/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---------- Model Checkpoints (Large Files - 26GB+) ----------
# These should be stored externally (S3, shared volume, or separate LFS repo)
VSP-LLM/checkpoints/Llama-2-7b-hf/
VSP-LLM/checkpoints/*.pt
VSP-LLM/checkpoints/*.pth
auto_avsr/exp/          # Training experiments
auto_avsr/lightning_logs/

# EXCEPTION: Track README for checkpoint documentation
!VSP-LLM/checkpoints/README.md
!VSP-LLM/checkpoints/.gitkeep

# Golden k-means model (small enough to track, ~50MB)
# If it becomes large, consider using Git LFS
!VSP-LLM/flat_kmeans_200.bin
!VSP-LLM/*.bin

# ---------- Whisper Model Cache (1.4GB+) ----------
**/whisper_cache/
**/medium.pt

# ---------- Docker Build Artifacts ----------
vsp_docker/galaxy_export/  # Container sync target (generated, not source)
*.tar
*.tar.gz
save.log
docker_save.err

# ---------- IDE and Editor Files ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.project
.pydevproject

# ---------- Temporary and Log Files ----------
*.log
*.tmp
*.bak
.cache/
.nv/
tmp/
temp/

# ---------- SSH Keys and Secrets ----------
.ssh/
*.pem
*.key
.env
.env.local
.env.production
credentials.json
secrets/
*.secret

# ---------- User-Specific Config ----------
.bash_history
.bash_logout
.bashrc
.profile
.python_history
.claude/
.claude.json
.claude.json.backup
.copilot/
.docker/
.config/
.dotnet/
.git-credentials
.gitconfig
.ipython/
.jupyter/
.local/
.gnupg/
.nv/
.sudo_as_admin_successful
.uniface/
.viminfo
.vscode-server/
.vsp-ui.log
.vsp-ui.pid
.wget-hsts
.lesshst

# ---------- OS-Specific Files ----------
# macOS
.AppleDouble
.LSOverride
Icon
._*

# Linux
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- Fairseq Build Artifacts ----------
# Submodules have their own .gitignore, but exclude at root level too
VSP-LLM/fairseq/build/
VSP-LLM/fairseq/fairseq.egg-info/
auto_avsr/fairseq/build/

# ---------- Media Files (Videos and Audio) ----------
# IMPORTANT: Exclude ALL video and audio files from git
*.mp4
*.mkv
*.avi
*.mov
*.flv
*.wmv
*.webm
*.m4v
*.mpg
*.mpeg
*.3gp
*.wav
*.mp3
*.aac
*.flac
*.ogg
*.m4a

# ---------- Jupyter Notebooks ----------
.ipynb_checkpoints/
*.ipynb

# ---------- Node Modules (if any JS tooling exists) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Backup Files ----------
*.bak
*.backup
*.old
*~

# ---------- Archived Documentation (Keep Recent Only) ----------
# Uncomment to exclude old feature docs after merge
# docs/archived/

# ---------- Large Binary Assets ----------
*.pkl
*.pickle
*.npy
*.npz
*.h5
*.hdf5

# Exception: Small reference files
!reference/*.pkl
!configs/*.pkl

# ---------- Git Backup Directories ----------
.git-backup/
.git-old-backup/
