# ==================================================
# VSP Pipeline Root .gitignore
# ==================================================
# Created: 2026-01-29
# Purpose: Exclude large data directories, models, and build artifacts

# ---------- Data Directories (Large, Generated) ----------
# These are generated by pipeline runs and should not be tracked
# User input videos (100MB+)
vsp_input/
# Copied raw videos
flat/
# ASR transcription outputs
flat_wrd/
# Text format transcriptions
flat_txt/
# Preprocessed directory structure
preprocess_ready_flat/
# Segmented videos (any segment duration: seg4, seg12, etc.)
preprocessed_flat_seg*/
# Archived pipeline outputs
flat_runs_archive/
# Extracted HuBERT features
flat_features/
# K-means cluster labels
flat_labels/
# Decoding outputs
decode/

# EXCEPTION: .transcriptions should be optionally tracked for backup
# Uncomment below to track transcriptions in git
# !vsp_input/.transcriptions/
# !vsp_input/.transcriptions/*.wrd
# !vsp_input/.transcriptions/metadata.json

# ---------- Python Virtual Environments ----------
*-venv/
venv/
.venv/
env/
pre-process-venv/
vsp-llm-yoad-venv/
project/ron/.venv/

# ---------- Python Build Artifacts ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
!scripts/build/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---------- Model Checkpoints (Large Files - 26GB+) ----------
# These should be stored externally (S3, shared volume, or separate LFS repo)
VSP-LLM/checkpoints/Llama-2-7b-hf/
VSP-LLM/checkpoints/*.pt
VSP-LLM/checkpoints/*.pth
# Training experiments
auto_avsr/exp/
auto_avsr/lightning_logs/

# EXCEPTION: Track README for checkpoint documentation
!VSP-LLM/checkpoints/README.md
!VSP-LLM/checkpoints/.gitkeep

# Golden k-means model (small enough to track, ~50MB)
# If it becomes large, consider using Git LFS
!VSP-LLM/flat_kmeans_200.bin
!VSP-LLM/*.bin

# ---------- Whisper Model Cache (1.4GB+) ----------
**/whisper_cache/
**/medium.pt

# ---------- Docker Build Artifacts ----------
# Container sync target (generated, not source)
vsp_docker/galaxy_export/
*.tar
*.tar.gz
save.log
docker_save.err

# ---------- IDE and Editor Files ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.project
.pydevproject

# ---------- Temporary and Log Files ----------
*.log
*.tmp
*.bak
.cache/
.nv/
tmp/
temp/

# ---------- SSH Keys and Secrets ----------
.ssh/
*.pem
*.key
.env
.env.local
.env.production
credentials.json
secrets/
*.secret

# ---------- User-Specific Config ----------
.bash_history
.bash_logout
.bashrc
.profile
.python_history
.claude/
.claude.json
.claude.json.backup
.copilot/
.docker/
.config/
.dotnet/
.git-credentials
.gitconfig
.ipython/
.jupyter/
.local/
.gnupg/
.nv/
.sudo_as_admin_successful
.uniface/
.viminfo
.vscode-server/
.vsp-ui.log
.vsp-ui.pid
.wget-hsts
.lesshst

# ---------- OS-Specific Files ----------
# macOS
.AppleDouble
.LSOverride
Icon
._*

# Linux
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------- Fairseq Build Artifacts ----------
# Submodules have their own .gitignore, but exclude at root level too
VSP-LLM/fairseq/build/
VSP-LLM/fairseq/fairseq.egg-info/
auto_avsr/fairseq/build/

# ---------- Media Files (Videos and Audio) ----------
# IMPORTANT: Exclude ALL video and audio files from git
*.mp4
*.mkv
*.avi
*.mov
*.flv
*.wmv
*.webm
*.m4v
*.mpg
*.mpeg
*.3gp
*.wav
*.mp3
*.aac
*.flac
*.ogg
*.m4a

# ---------- Jupyter Notebooks ----------
.ipynb_checkpoints/
*.ipynb

# ---------- Node Modules (if any JS tooling exists) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Backup Files ----------
*.bak
*.backup
*.old
*~

# ---------- Archived Documentation (Keep Recent Only) ----------
# Uncomment to exclude old feature docs after merge
# docs/archived/

# ---------- Large Binary Assets ----------
*.pkl
*.pickle
*.npy
*.npz
*.h5
*.hdf5

# Exception: Small reference files
!reference/*.pkl
!configs/*.pkl

# ---------- Git Backup Directories ----------
.git-backup/
.git-old-backup/

# ---------- TeX Live Cache ----------
.texlive2021/

# ---------- LLM Model Configs (tracked separately) ----------
Llama-2-7b-hf/

# ---------- Archive of External Repos ----------
_archive/

# ---------- Build / Data / Model Directories ----------
build_assets/
data/
datasets/
face_alignment/
face_detection/
finetune_data/
finetune_eval_baseline_sweep/
finetune_output_r16/
finetune_output_r64/
golden_weights/baseline_*/

# ---------- Pipeline Outputs & Results (large) ----------
english_full_results/decode_output/
english_full_results/flat_kmeans_200.bin
english_full_results/flat_labels/
english_full_results/manifests/
english_full_results/segment_metadata.json
english_full_results_*/
english_full_nbest_eval/
outputs/
vsp_input_tuning/
tuning_results/

# ---------- Logs & Transferable Resources ----------
logs/
generally_useful/

# ---------- Generated HTML Reports ----------
# Tuning experiment reports (regenerable, findings captured in CSVs and markdown)
docs/tuning/html-reports/*.html
docs/tuning/experiments/*/report/report.html

# ---------- Misc Large / Generated Files ----------
FINAL_PRESENTATION.pptx
html_report_full.png
html_report_top.png
snap/
*.sha256
*.gif

# Loose images dropped at repo root (screenshots, working artifacts).
# Place presentation images under presentation_materials_*/ or docs/.
/*.png
/*.jpg
/*.jpeg