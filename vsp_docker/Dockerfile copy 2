FROM nvidia/cuda:12.1.0-base-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

# --- System deps ---
RUN apt-get update && apt-get install -y \
    python3 python3-venv python3-pip python3-dev \
    ffmpeg git \
    libglib2.0-0 libsm6 libxext6 libxrender1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Copy your standalone bundle (code + configs + models, but not venvs/mp4)
COPY galaxy_export/ ./

# ---------- CREATE TWO VIRTUAL ENVS ----------
# auto_avsr / preprocessing env
RUN python3 -m venv /workspace/auto_avsr/pre-process-venv

# VSP-LLM env
RUN python3 -m venv /workspace/vsp-llm-yoad-venv

# ---------- GPU TORCH FOR auto_avsr (pre-process-venv) ----------
RUN /workspace/auto_avsr/pre-process-venv/bin/python -m pip install --upgrade pip && \
    /workspace/auto_avsr/pre-process-venv/bin/pip install \
      --index-url https://download.pytorch.org/whl/cu121 \
      torch==2.2.2+cu121 \
      torchvision==0.17.2+cu121 \
      torchaudio==2.2.2+cu121

